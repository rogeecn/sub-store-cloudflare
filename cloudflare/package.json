{
  "name": "sub-store-cloudflare",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "check": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --config wrangler.deploy.local.jsonc",
    "migrate:local": "wrangler d1 migrations apply sub-store-cloudflare --local --config wrangler.deploy.local.jsonc",
    "migrate:remote": "wrangler d1 migrations apply sub-store-cloudflare --remote --config wrangler.deploy.local.jsonc",
    "types": "wrangler types"
  },
  "dependencies": {
    "hono": "^4.12.28",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.4",
    "@cloudflare/workers-types": "^5.20260710.1",
    "@types/node": "^22.18.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  }
}
